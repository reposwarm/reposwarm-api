{
  "name": "reposwarm-api",
  "version": "1.2.0",
  "description": "RepoSwarm API Server — standalone REST API for repos, workflows, prompts, wiki",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && cp src/providers.json dist/providers.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1000.0",
    "@aws-sdk/client-codecommit": "^3.750.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@temporalio/client": "^1.15.0",
    "aws-jwt-verify": "^4.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.18.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=24"
  }
}
